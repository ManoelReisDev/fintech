{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2020": true
  },
  "ignorePatterns": ["dist", ".eslintrc.cjs"],
  "plugins": ["react", "typescript"],
  "rules": {
    "no-unused-vars": "off",
    "react/exhaustive-deps": "warn",
    "react/only-export-components": "off",
    "react/rules-of-hooks": "error"
  }
}
